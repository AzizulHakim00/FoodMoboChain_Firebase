<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/brand_cream"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="720dp"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="40dp"
        android:paddingEnd="24dp"
        android:paddingBottom="32dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_logo"
                android:contentDescription="@string/app_name"
                android:padding="10dp"
                android:src="@drawable/ic_food_bag" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:fontFamily="sans-serif-black"
                android:text="@string/app_name"
                android:textColor="@color/brand_ink"
                android:textSize="20sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/authEyebrow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="38dp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.15"
            android:text="WELCOME BACK"
            android:textColor="@color/brand_green"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/authTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="sans-serif-black"
            android:lineSpacingExtra="-5dp"
            android:text="Sign in and keep\nyour cravings close."
            android:textColor="@color/brand_ink"
            android:textSize="40sp" />

        <EditText
            android:id="@+id/nameInput"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="28dp"
            android:background="@drawable/bg_input"
            android:hint="Full name"
            android:inputType="textPersonName"
            android:paddingHorizontal="16dp"
            android:textColor="@color/brand_ink"
            android:textColorHint="@color/brand_muted"
            android:visibility="gone" />

        <EditText
            android:id="@+id/emailInput"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input"
            android:hint="Email address"
            android:inputType="textEmailAddress"
            android:paddingHorizontal="16dp"
            android:textColor="@color/brand_ink"
            android:textColorHint="@color/brand_muted" />

        <EditText
            android:id="@+id/passwordInput"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input"
            android:hint="Password (minimum 6 characters)"
            android:inputType="textPassword"
            android:paddingHorizontal="16dp"
            android:textColor="@color/brand_ink"
            android:textColorHint="@color/brand_muted" />

        <Spinner
            android:id="@+id/roleInput"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input"
            android:paddingHorizontal="12dp"
            android:visibility="gone" />

        <Button
            android:id="@+id/submitButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_primary_button"
            android:fontFamily="sans-serif-medium"
            android:text="Sign in"
            android:textAllCaps="false"
            android:textColor="@color/brand_white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/modeButton"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_outline_button"
            android:text="New here? Create an account"
            android:textAllCaps="false"
            android:textColor="@color/brand_green"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/forgotButton"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_gravity="center_horizontal"
            android:gravity="center"
            android:text="Forgot password?"
            android:textColor="@color/brand_muted"
            android:textStyle="bold" />

        <ProgressBar
            android:id="@+id/authProgress"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:indeterminateTint="@color/brand_green"
            android:visibility="gone" />
    </LinearLayout>
</ScrollView>
